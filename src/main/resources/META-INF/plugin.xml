<idea-plugin>
    <id>io.github.tonygnk.cataloglens</id>
    <name>CatalogLens</name>
    <vendor email="tonygnkpublic@gmail.com" url="https://github.com/tonygnk">tonygnk</vendor>

    <description><![CDATA[
        Makes Gradle version catalogs (<code>libs.versions.toml</code>) navigable.
        <ul>
            <li>Ctrl/Cmd-click any <code>[libraries]</code> entry to open its Maven Central or MvnRepository page.</li>
            <li>Gutter icons on <code>[versions]</code> entries link to upstream release notes and changelogs.</li>
            <li>Sort catalog groups A&#8594;Z &#8212; floating editor icon opens a diff preview; apply or cancel. Blank lines and comments delimit groups and stay in place.</li>
        </ul>
        All links are built locally — no network access while editing.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.toml.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <psi.referenceContributor language="TOML"
            implementation="io.github.tonygnk.cataloglens.links.LibrariesReferenceContributor"/>
        <codeInsight.lineMarkerProvider language="TOML"
            implementationClass="io.github.tonygnk.cataloglens.markers.VersionsLineMarkerProvider"/>

        <applicationConfigurable parentId="tools"
            id="io.github.tonygnk.cataloglens.settings"
            displayName="CatalogLens"
            instance="io.github.tonygnk.cataloglens.settings.CatalogLensConfigurable"/>
        <projectConfigurable parentId="io.github.tonygnk.cataloglens.settings"
            id="io.github.tonygnk.cataloglens.settings.project"
            displayName="Project Mappings"
            instance="io.github.tonygnk.cataloglens.settings.CatalogLensProjectConfigurable"/>

        <editorFloatingToolbarProvider
            implementation="io.github.tonygnk.cataloglens.sort.SortCatalogFloatingToolbarProvider"/>
    </extensions>

    <actions>
        <action id="CatalogLens.SortCatalog"
                class="io.github.tonygnk.cataloglens.sort.SortCatalogAction"
                text="Sort Catalog Groups A→Z"
                description="Sort entries alphabetically within each group of the version catalog"
                icon="AllIcons.ObjectBrowser.Sorted">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <group id="CatalogLens.SortToolbarGroup">
            <reference ref="CatalogLens.SortCatalog"/>
        </group>
    </actions>
</idea-plugin>
